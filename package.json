{
	"name": "@typeup/dom",
	"version": "1.0.10",
	"description": "Document Object Model for TypeUp.",
	"author": "Simon Mika <simon@mika.se>",
	"license": "MIT",
	"private": false,
	"repository": {
		"type": "git",
		"url": "git+https://github.com/typeup/dom.git"
	},
	"bugs": {
		"url": "https://github.com/typeup/dom/issues"
	},
	"homepage": "https://github.com/typeup",
	"type": "module",
	"types": "./dist/types/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/types/index.d.ts",
				"default": "./dist/mjs/index.js"
			}
		}
	},
	"types": "./dist/types/index.d.ts",
	"files": [
		"dist",
		"*.ts",
		"!*.spec.ts",
		"!**/test/**",
		"LICENSE",
		"README.md"
	],
	"git": {
		"tagName": "release-${version}"
	},
	"github": {
		"release": true
	},
	"scripts": {
		"lint": "biome format .",
		"format": "biome format --write .",
		"type-check": "tsc --noEmit",
		"build": "tsc -p tsconfig.build.json",
		"test": "vitest --run",
		"coverage": "vitest --coverage",
		"clean": "rimraf dist node_modules coverage",
		"verify": "npm run build && npm run test && npm run lint && npm audit --omit=dev"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.13",
		"@vitest/coverage-v8": "^4.1.5",
		"rimraf": "^6.1.3",
		"typescript": "6.0.3",
		"vite": "^8.0.10",
		"vitest": "^4.1.5"
	},
	"dependencies": {
		"mendly": "^3.1.1-beta.15"
	}
}
